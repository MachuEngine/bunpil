# ── LLM 백엔드 ──────────────────────────────────────────────────────
LLM_BACKEND=local              # local | runpod
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b        # 생성 전용. 개발 시 1.5b로 교체 가능
OLLAMA_JUDGE_MODEL=qwen2.5:14b # Judge 전용 (미설정 시 OLLAMA_MODEL 폴백)

# RunPod 서버리스 (Phase 8) — 실값은 .env에만, 커밋 금지
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_endpoint_id

# ── RAG 설정 (Phase 1) ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=/data/chroma_db   # 로컬 개발 시: ./chroma_db
BGE_EMBED_MODEL=BAAI/bge-m3
BGE_RERANK_MODEL=BAAI/bge-reranker-base

# ── 앱 설정 ─────────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # 주의: DEBUG 수준에서도 PII 로그 금지

# ── LangSmith 트레이싱 (선택) ────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=bunpil
